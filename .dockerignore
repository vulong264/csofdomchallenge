# Dependencies — reinstalled inside the image via `npm ci`
node_modules
.pnp
.pnp.*

# Build artifacts — regenerated by `next build` in the builder stage
.next
out
build
*.tsbuildinfo
next-env.d.ts

# Local env / secrets — never bake into the image (ANTHROPIC_API_KEY etc.)
.env
.env.*
!.env.example
*.pem

# Tests / coverage — not needed at runtime
coverage

# Version control & tooling
.git
.gitignore
.github
.vscode
.idea
.claude

# OS / editor cruft
.DS_Store
*.log
npm-debug.log*

# Docs & meta — not part of the runtime
README.md
AGENTS.md
CLAUDE.md

# Docker
Dockerfile
.dockerignore
